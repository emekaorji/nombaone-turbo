# ============================================================================
# nombaone — root env template (placeholders only). Copy to `.env` and fill in.
# Each app also has its own apps/<app>/.env.example. Drizzle (core-db/docs-db)
# reads INFRA_DATABASE_URL / DOCS_DATABASE_URL from here.
# ONE deployment serves BOTH account modes (sandbox + live); the mode is chosen
# per request from the API-key prefix, not the deployment.
# ============================================================================

NODE_ENV=development

# Deployment RING — development | production (defaults to development). NOT the
# account mode: that is sandbox|live, derived per request from the key prefix
# (nbo_sandbox_… / nbo_live_…). `live` keys are only honoured on production.
INFRA_ENVIRONMENT=development

# Platform database (PostgreSQL; Neon in prod). Read by api/console/admin/checkout + drizzle.
INFRA_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone

# Docs feedback/analytics DB (separate from the platform DB).
DOCS_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone_docs

# Redis (idempotency, rate-limit, BullMQ queues + scheduler).
REDIS_URL=redis://localhost:6379

# 32-byte key for column-level PII encryption (TOTP secrets, etc.). MUST be
# byte-identical across api + console.
INFRA_PII_ENCRYPTION_KEY=replace-with-32-byte-key

# Console opaque-token session cookie secret (32+ random bytes).
CONSOLE_SESSION_COOKIE_SECRET=replace-with-console-cookie-secret

# Admin operator JWT signing secret (with tokenVersion revocation).
AUTH_JWT_SECRET=replace-with-operator-jwt-secret

# Public (browser) vars
NEXT_PUBLIC_APP_URL=http://localhost:8010
NEXT_PUBLIC_NOMBAONE_ENV=local

# Local-only: skip the API rate limiter. Never set in production.
# DISABLE_API_RATE_LIMIT=true
