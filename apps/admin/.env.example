# ============================================================================
# apps/admin — Nombaone internal operator panel (admin.nombaone.xyz)
# Copy to `.env` and fill in. The panel runs on a SINGLE database: the infra
# platform DB (@nombaone/core-db) holds both the platform tables AND the
# operator-auth tables (operators, admin_audit_log, operator_preferences).
# ============================================================================

NODE_ENV=development

# The infra platform database. Used for BOTH operator auth (login/sessions) and
# all operator-panel reads/writes. Same value the API (apps/api) uses.
INFRA_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone_infra

# AES key for column-level PII (BVN, ID numbers, …) — MUST be byte-identical to
# apps/api's INFRA_PII_ENCRYPTION_KEY so the KYB masked-reveal can decrypt.
INFRA_PII_ENCRYPTION_KEY=replace-with-32-byte-key

# Secret used to sign operator session JWTs (with the tokenVersion claim for
# instant revocation). 32+ random bytes.
AUTH_JWT_SECRET=replace-with-32-byte-operator-jwt-secret

# Absolute base URL the panel is served from (operator invite / password-reset links).
ADMIN_BASE_URL=http://localhost:8020

# Deployment ring — drives the topbar env pill. One of: local | preview | production.
NEXT_PUBLIC_NOMBAONE_ENV=local

# Transactional email (operator invites + password resets) via Resend.
EMAIL_FROM=Nombaone <noreply@nombaone.xyz>

# ─── Bootstrap operator (used by `pnpm -F @nombaone/admin seed:admin`) ─────────
# Upserted as a super_admin so you can sign in to a fresh database.
ADMIN_BOOTSTRAP_EMAIL=operator@nombaone.local
ADMIN_BOOTSTRAP_PASSWORD=Operator123!
ADMIN_BOOTSTRAP_NAME=Local Operator
