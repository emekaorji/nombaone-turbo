# App
NODE_ENV=development
PORT=8000

# Deployment RING — development | production (defaults to development).
# ONE ring serves BOTH account modes; the per-request mode comes from the API-key
# prefix (nbo_sandbox_… / nbo_live_…), NOT from this var. `live` keys + the live
# Nomba client are only honoured when INFRA_ENVIRONMENT=production; set this to
# `production` to do live work (locally or deployed).
INFRA_ENVIRONMENT=development

# Platform database (PostgreSQL; Neon in prod)
INFRA_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone

# Redis (idempotency, rate-limit, BullMQ queues + scheduler)
REDIS_URL=redis://localhost:6379

# 32-byte key (hex or base64) for column-level PII encryption (e.g. TOTP secrets).
# MUST be byte-identical to the console's INFRA_PII_ENCRYPTION_KEY.
INFRA_PII_ENCRYPTION_KEY=replace-with-32-byte-key

# Signs the opaque tokens behind the customer-facing action pages (/i, /pm) — the
# pay-this-invoice and update-your-card links a member receives by email. Rotating it
# invalidates every link already sitting in a customer's inbox.
INFRA_ACTION_TOKEN_SECRET=replace-with-a-long-random-secret

# Host-based key guard (DX): a request on the live host must carry a nbo_live_ key,
# and the sandbox host a nbo_sandbox_ key (else 401 API_KEY_HOST_MISMATCH). Defaults
# below are for production; localhost/tunnels match neither → not enforced. Set a
# value to empty to disable that side.
INFRA_LIVE_API_HOST=api.nombaone.xyz
INFRA_SANDBOX_API_HOST=sandbox.api.nombaone.xyz

# Local only — skip the API rate limiter. Never set in production.
# DISABLE_API_RATE_LIMIT=true

# ── Nomba credentials, per account MODE ───────────────────────────────────────
# One deployment serves both — populate the set(s) you use. Sandbox works on any ring;
# live is only usable on INFRA_ENVIRONMENT=production.
#
# There is deliberately NO *_SUBACCOUNT_ID. Nomba sub-accounts cannot be minted through
# the API, and a sub-account belongs to a MERCHANT, not to a deployment. Money collects
# into the ONE platform account; each merchant's balance lives in our double-entry ledger
# (`tenant_settlement:{accountRef}`) and is paid out on withdrawal.

# Nomba SANDBOX account (mode = sandbox)
NOMBA_SANDBOX_BASE_URL=********
NOMBA_SANDBOX_PARENT_ACCOUNT_ID=********
NOMBA_SANDBOX_CLIENT_ID=********
NOMBA_SANDBOX_CLIENT_SECRET=********
NOMBA_SANDBOX_WEBHOOK_SIGNATURE_KEY=********

# Nomba LIVE account (mode = live) — only honoured on INFRA_ENVIRONMENT=production
NOMBA_LIVE_BASE_URL=********
NOMBA_LIVE_PARENT_ACCOUNT_ID=********
NOMBA_LIVE_CLIENT_ID=********
NOMBA_LIVE_CLIENT_SECRET=********
NOMBA_LIVE_WEBHOOK_SIGNATURE_KEY=********

# Does a merchant's withdrawal actually reach their bank?
# OFF ⇒ the payout posts the ledger debit and records `ledger_posted` but sends NO money:
# the merchant's balance drops and nothing arrives. That is a lie in the product, so it
# has to be a deliberate, visible choice — never a silent default.
NOMBA_PAYOUT_ENABLED=false

# ── Customer email (dunning, receipts, payment links) ─────────────────────────
# `log` is REFUSED in production. Printing a dunning warning to stdout instead of sending
# it is worse than refusing to boot, because it looks like it worked.
COMMS_TRANSPORT=log
COMMS_FROM=Nomba One <billing@mail.nombaone.xyz>

# COMMS_TRANSPORT=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=********
SMTP_PASSWORD=********

# COMMS_TRANSPORT=resend
# RESEND_API_KEY=********

# ── Sweeps (all have sane defaults; override only if you mean to) ─────────────
# The billing sweep and the awaiting-payment sweep MUST stay at every-minute for a
# wall-clock cadence (`minute × 10`) to bill and settle on time.
# BILLING_SWEEP_CRON=* * * * *
# AWAITING_PAYMENT_SWEEP_CRON=* * * * *
# WEBHOOK_MAINTENANCE_CRON=* * * * *
# DUNNING_SWEEP_CRON=*/15 * * * *
