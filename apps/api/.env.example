# App
NODE_ENV=development
PORT=8000

# Deployment RING — development | production (defaults to development).
# ONE ring serves BOTH account modes; the per-request mode comes from the API-key
# prefix (nbo_sandbox_… / nbo_live_…), NOT from this var. `live` keys + the live
# Nomba client are only honoured when INFRA_ENVIRONMENT=production; set this to
# `production` to do live work (locally or deployed).
INFRA_ENVIRONMENT=development

# Platform database (PostgreSQL; Neon in prod)
INFRA_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone

# Redis (idempotency, rate-limit, BullMQ queues + scheduler)
REDIS_URL=redis://localhost:6379

# 32-byte key (hex or base64) for column-level PII encryption (e.g. TOTP secrets).
# MUST be byte-identical to the console's INFRA_PII_ENCRYPTION_KEY.
INFRA_PII_ENCRYPTION_KEY=replace-with-32-byte-key

# Local only — skip the API rate limiter. Never set in production.
# DISABLE_API_RATE_LIMIT=true

# Nomba credentials, per account MODE. One deployment serves both — populate the
# set(s) you use. Sandbox works on any ring; live is only usable on production.

# ── Nomba SANDBOX account (mode = sandbox) ────────────────────────────────
NOMBA_SANDBOX_BASE_URL=********
NOMBA_SANDBOX_PARENT_ACCOUNT_ID=********
NOMBA_SANDBOX_SUBACCOUNT_ID=********
NOMBA_SANDBOX_CLIENT_ID=********
NOMBA_SANDBOX_CLIENT_SECRET=********
NOMBA_SANDBOX_WEBHOOK_SIGNATURE_KEY=********

# ── Nomba LIVE account (mode = live) — only used on INFRA_ENVIRONMENT=production ──
NOMBA_LIVE_BASE_URL=********
NOMBA_LIVE_PARENT_ACCOUNT_ID=********
NOMBA_LIVE_SUBACCOUNT_ID=********
NOMBA_LIVE_CLIENT_ID=********
NOMBA_LIVE_CLIENT_SECRET=********
NOMBA_LIVE_WEBHOOK_SIGNATURE_KEY=********
