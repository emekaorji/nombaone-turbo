# ============================================================================
# apps/checkout — Nombaone hosted checkout (checkout.nombaone.xyz)
# Copy to `.env` and fill in. The checkout is UNAUTHENTICATED: it resolves the
# resource solely by its public reference and reads through @nombaone/sara — no
# API layer. The org + mode are derived FROM the resource, never a caller.
# ============================================================================

NODE_ENV=development

# The infra platform database (same value apps/api and the console use). The
# checkout looks the resource up by its globally-unique public reference, reads
# the org + mode off that row, then resolves the resource through the
# domain (sara/example getExampleByReference) within that derived scope.
INFRA_DATABASE_URL=postgresql://user:password@localhost:5432/nombaone_infra

# HMAC secret for signed end-customer action tokens (`/i/<token>` pay invoice,
# `/pm/<token>` update payment method). MUST be the SAME value as apps/api's
# INFRA_ACTION_TOKEN_SECRET — the api mints the tokens, the checkout verifies
# them. Generate with: openssl rand -base64 32
INFRA_ACTION_TOKEN_SECRET=change-me-shared-with-apps-api
