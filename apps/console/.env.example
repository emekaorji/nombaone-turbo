# Postgres connection string (Neon). MUST point at the same infra database the
# API (apps/api) uses. Read by both the neon-http driver (reads / one-shot
# writes) and the neon edge-pool driver (interactive-tx writes: signup, KYB).
INFRA_DATABASE_URL=

# AES key for PII at rest (BVN, ID numbers, TOTP secrets). MUST be byte-for-byte
# identical to apps/api's INFRA_PII_ENCRYPTION_KEY, or encrypted columns
# written by one app are unreadable by the other.
INFRA_PII_ENCRYPTION_KEY=

# Secret used to sign/verify the console's CSRF + cookie state. 32+ random bytes.
CONSOLE_SESSION_COOKIE_SECRET=

# Absolute base URL the console is served from (used for links in emails, etc.).
NEXT_PUBLIC_APP_URL=http://localhost:8010

# Deployment ring — drives the topbar env pill. One of: local | preview | production.
NEXT_PUBLIC_NOMBAONE_ENV=local

# The money engine (apps/api). The console NEVER writes money directly — every
# charge, subscribe, refund and payout is an HTTP call to this API, authenticated
# with the org's encrypted bridge key. Point it at the API you actually want to move
# money on: a console aimed at the wrong engine will silently bill the wrong tenant.
NOMBAONE_API_URL=http://localhost:8000

# ── Transactional email (password reset, invites) ─────────────────────────────
# Same transport contract as apps/api. `log` is REFUSED in production — a password
# reset printed to stdout instead of sent is worse than a boot failure, because it
# looks like it worked.
COMMS_TRANSPORT=log
COMMS_FROM=Nomba One <billing@mail.nombaone.xyz>

# COMMS_TRANSPORT=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
