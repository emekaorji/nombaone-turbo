# Base URL of the Nombaone Infra public API the playground proxy forwards to.
# The explorer is sandbox-only: it targets the sandbox host, which accepts only
# `nbo_test_` keys (a `nbo_live_` key is rejected by the proxy outright).
NEXT_PUBLIC_INFRA_API_BASE=https://sandbox.api.nombaone.xyz/v1

# Deployment ring — drives the topbar env pill. One of: local | preview | production.
NEXT_PUBLIC_NOMBAONE_ENV=local

# Optional shared read-only sandbox key so GET examples work before a user
# pastes their own test key. MUST be an `nbo_test_` key. Leave blank to
# require the user to bring their own.
INFRA_DEMO_SANDBOX_KEY=

# Dedicated docs analytics database (@nombaone/docs-db) for the "Was this page
# helpful?" widget. A SEPARATE Neon instance from the financial infra DB. Only
# read at runtime when feedback is written; the build does not require it.
DOCS_DATABASE_URL=postgresql://user:password@localhost:9100/nombaone_docs
