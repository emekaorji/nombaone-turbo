{
  "name": "@nombaone/docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 8030",
    "build": "pnpm run check:frontmatter && pnpm run check:style && pnpm run check:links && pnpm run check:openapi && pnpm run search:index && pnpm run ask:index && pnpm run agent:native && next build",
    "start": "next start --port 8030",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "check:frontmatter": "tsx scripts/check-frontmatter.ts",
    "check:links": "tsx scripts/check-links.ts",
    "check:openapi": "tsx scripts/check-openapi-honesty.ts",
    "search:index": "tsx scripts/build-search-index.ts",
    "agent:native": "tsx scripts/build-agent-native.ts",
    "check:style": "tsx scripts/check-style.ts",
    "ask:index": "tsx scripts/build-ask-index.ts"
  },
  "dependencies": {
    "@ai-sdk/groq": "^4.0.5",
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@nombaone/core-contracts": "workspace:*",
    "@nombaone/docs-db": "workspace:*",
    "@nombaone/errors": "workspace:*",
    "@nombaone/sara": "workspace:*",
    "@nombaone/ui": "workspace:*",
    "@nombaone/utils": "workspace:*",
    "ai": "^7.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.475.0",
    "minisearch": "^7.2.0",
    "next": "16.2.4",
    "next-themes": "^0.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
