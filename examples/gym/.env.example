# Iron Republic — the NombaOne reference merchant.
# Copy to .env and fill in.

# Merchant sandbox key (nbo_sandbox_…). Server-side only.
NOMBAONE_API_KEY=

# The engine to talk to. Point at the local engine in development; omit in
# production (the SDK derives the host from the key prefix).
NOMBAONE_BASE_URL=http://localhost:8000

# The PLAINTEXT signing secret (nbo_whsec_…) shown ONCE when you register
# this app's webhook endpoint (<GYM_BASE_URL>/api/webhooks) with the engine.
GYM_WEBHOOK_SECRET=

# Where this app is reachable — used as the hosted-checkout callback origin.
GYM_BASE_URL=http://localhost:8060
