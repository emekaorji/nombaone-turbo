# The NombaOne money engine. Point this at the API you actually want to move money on.
NOMBAONE_API_KEY=nbo_live_or_sandbox_key
NOMBAONE_BASE_URL=https://api.nombaone.xyz

# Where Nomba returns the payer after a hosted checkout.
GYM_BASE_URL=https://your-gym-domain

# Verifies every inbound webhook. It belongs to ONE registered endpoint — rotate the
# endpoint and this changes with it:
#   POST /v1/webhooks {"url":"https://your-gym-domain/api/webhooks"}
GYM_WEBHOOK_SECRET=nbo_whsec_...

# ── The gym's OWN database ───────────────────────────────────────────────────
# Members, password hashes, sessions, pay-links, notices. Turso (libSQL), NOT a local file.
#
# It WAS a local SQLite file, and that was fine on a laptop and fatal in production: a deployed
# container's disk is ephemeral, so every redeploy would silently reset the entire membership; on a
# read-only filesystem the first request would throw outright; and horizontally you would get one
# database PER INSTANCE, so a member who signed up on one and signed in on another simply would not
# exist. Same SQLite, kept somewhere that survives a deploy.
DATABASE_URL=libsql://your-db.turso.io
DATABASE_SECRET=your-turso-auth-token
