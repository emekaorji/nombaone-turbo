{
  "name": "@nombaone/example-gym",
  "version": "0.1.0",
  "private": true,
  "//": [
    "This example consumes the PUBLIC SDK only (@nombaone/node from npm) \u2014 never import from packages/*.",
    "That constraint is the point: if the published SDK cannot build this app, no merchant can build theirs."
  ],
  "scripts": {
    "dev": "next dev --port 8060",
    "build": "next build",
    "start": "next start --port 8060",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@nombaone/node": "^0.1.5",
    "better-sqlite3": "^12.11.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
