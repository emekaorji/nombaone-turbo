{
  "name": "nombaone",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "check:boundaries": "node toolings/check-package-boundaries.mjs"
  },
  "devDependencies": {
    "@nombaone/prettier-config": "workspace:*",
    "prettier": "^3.2.0",
    "turbo": "^2.10.0",
    "typescript": "^5.8.2"
  },
  "prettier": "@nombaone/prettier-config",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "ioredis": "5.11.1",
      "@types/react": "~19.2.0",
      "@types/react-dom": "~19.2.0"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
}
