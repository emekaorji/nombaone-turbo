{
  "name": "@nombaone/core-db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pool": "./src/pool.ts",
    "./rls": "./src/rls.ts",
    "./edge-pool": "./src/edge-pool.ts",
    "./schema": "./src/schema.ts",
    "./serverless": "./src/serverless.ts",
    "./admin-auth": "./src/schema/admin-auth.ts",
    "./saved-views": "./src/schema/saved-views.ts",
    "./operator-preferences": "./src/schema/operator-preferences.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@nombaone/utils": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.13.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nombaone/typescript-config": "workspace:*",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.5.13",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.4.0"
  }
}
