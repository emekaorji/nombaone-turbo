                  "fill": "$--foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The double-charge bug, and why idempotency keys aren't optional.",
                  "lineHeight": 1.1,
                  "fontFamily": "$--font-sans",
                  "fontSize": 34,
                  "fontWeight": "600",
                  "letterSpacing": -1.4
