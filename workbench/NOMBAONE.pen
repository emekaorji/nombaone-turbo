                    {
                      "id": "wpP4j",
                      "type": "ref",
                      "ref": "mVa8b",
                      "name": "Do you touch raw card data?",
                      "width": "fill_container",
                      "descendants": {
                        "wfJD8": {
                          "content": "Do you touch raw card data?"
                        },
                        "qzKZz": {
                          "content": "No. Card entry stays on Nomba's hosted, PCI-compliant page. No raw card number ever reaches our servers, and there is no publishable key to leak."
                        }
                      }
                    },
                    {
                      "id": "msYZ6",
                      "type": "ref",
                      "ref": "mVa8b",
                      "name": "How is customer data protected?",
                      "width": "fill_container",
                      "descendants": {
                        "wfJD8": {
                          "content": "How is customer data protected?"
                        },
                        "qzKZz": {
                          "content": "Data protection follows NDPR. Tenant data is isolated at the schema level, and every access is scoped to one organization."
                        }
                      }
                    },
                    {
                      "id": "OCaKY",
                      "type": "ref",
                      "ref": "mVa8b",
                      "name": "What is your uptime posture?",
                      "width": "fill_container",
                      "descendants": {
                        "wfJD8": {
                          "content": "What is your uptime posture?"
                        },
                        "qzKZz": {
                          "content": "The status page publishes real uptime. Incidents are posted openly, with a plainly-worded postmortem."
                        }
                      }
                    },
                    {
                      "id": "PmaeZ",
                      "type": "ref",
                      "ref": "mVa8b",
                      "name": "What about direct debit, payouts, and escrow?",
                      "width": "fill_container",
                      "descendants": {
                        "wfJD8": {
                          "content": "What about direct debit, payouts, and escrow?"
                        },
                        "qzKZz": {
                          "content": "Those rails are built and are being brought live. We describe them as capabilities, not as proven-at-scale, until each has run in production."
                        }
                      }
                    }
                  ]
                }
